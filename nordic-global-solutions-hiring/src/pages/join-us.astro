---
import Base from '../layouts/Base.astro';
const siteUrl = 'https://nordicglobal.netlify.app';
---

<Base>
  <Fragment slot="head">
    <meta property="og:image" content={`${siteUrl}/og-join-us.jpg`} />
    <meta property="og:image:secure_url" content={`${siteUrl}/og-join-us.jpg`} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Join Us — Nordic Global Solutions" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/join-us/`} />
    <meta property="og:title" content="Join Us — Nordic Global Solutions" />
    <meta property="og:description" content="Join us. Program. Open source. We're looking for people who want to learn, contribute, and build the future." />
    <meta property="og:site_name" content="Nordic Global Solutions" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Join Us — Nordic Global Solutions" />
    <meta name="twitter:description" content="Join us. Program. Open source. We're looking for people who want to learn, contribute, and build the future." />
    <meta name="twitter:image" content={`${siteUrl}/og-join-us.jpg`} />
    <meta name="twitter:image:alt" content="Join Us — Nordic Global Solutions" />
    <link rel="image_src" href={`${siteUrl}/og-join-us.jpg`} />
    <title>Join Us — Nordic Global Solutions</title>
    <meta name="description" content="Join us. Program. Open source. We're looking for people who want to learn, contribute, and build the future." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={`${siteUrl}/join-us/`} />
  </Fragment>

  <a href="/" class="back-link">← Back to landing</a>

  <div class="slides-wrapper">
    <div class="slide active" data-n="1">
      <div class="hero">
        <h1>Join <span class="highlight">Us</span></h1>
        <div class="divider"></div>
        <p class="tagline">Program. Open source. Build the future.</p>
        <p>We're looking for people who want to learn, contribute, and grow with us.</p>
      </div>
    </div>

    <div class="slide" data-n="2">
      <p class="caps">What We Offer</p>
      <h1>Learn & Program</h1>
      <p>Develop in the new age—AI-assisted coding, modern tooling, and real projects.</p>
      <ul>
        <li><strong>Learn</strong> — Cursor, AI workflows, next-gen dev tools</li>
        <li><strong>Program</strong> — React, TypeScript, Rust, Elixir, Phoenix</li>
        <li><strong>Grow</strong> — Work on real products from idea to production</li>
      </ul>
    </div>

    <div class="slide" data-n="3">
      <p class="caps">Open Source</p>
      <h1>Contribute & Build</h1>
      <p>Help with our open source repos. Code in the open. Make an impact.</p>
      <ul>
        <li><strong>Mimir</strong> — Knowledge & AI (Drive, Mind Map, RAG Chat)</li>
        <li><strong>AI Dev Suite</strong> — Local AI, Debugger, RAG</li>
        <li><strong>More</strong> — WorkFlowSpace, Affiliate Flow, and beyond</li>
      </ul>
      <p>Whether you're starting out or leveling up—we want to hear from you.</p>
    </div>

    <div class="slide" data-n="4">
      <p class="caps">Community</p>
      <h1>What is CO-FIKA?</h1>
      <p>CO-FIKA is your daily ritual sync with the NorthStarOS community — a 20–60 minute space to pause, connect, share state, and co-evolve.</p>
      <p>Inspired by the Nordic fika tradition, it's not a meeting — it's a ritual pause in time to align together at the edge of meaningful tech, community, and inner work. It's light. It's honest. It's alive.</p>
      <p>One part reflection. One part creation. One part evolution.</p>
      <p class="cta">
        <a href="https://discord.gg/HtKyx8j4Cs?event=1374706204193984532" target="_blank" rel="noopener" class="cta-discord">Join CO-FIKA on Discord</a>
      </p>
    </div>

    <div class="slide" data-n="5">
      <p class="caps">Community</p>
      <h1>Freelancer Meets Freelancer</h1>
      <p>Weekly Collaboration Meetup — break the isolation of freelancing with our weekly meetup designed to help independent professionals connect, collaborate, and grow together.</p>
      <p>Every Thursday 20:00–21:00 GMT. Join fellow freelancers across all fields to share projects, find collaborators, swap skills, and build your professional network on our Discord server.</p>
      <p class="cta">
        <a href="https://discord.gg/GJPMeKeGca?event=1370174743453372436" target="_blank" rel="noopener" class="cta-discord">Join Freelancer Meetup on Discord</a>
      </p>
    </div>

    <div class="slide" data-n="6">
      <div class="hero">
        <h1>Join the <span class="highlight">Team</span></h1>
        <div class="divider"></div>
        <p class="tagline">Program. Open source. Build with us.</p>
        <p class="cta">
          <a href="https://cal.com/whynotproductions/join-the-team?duration=15&overlayCalendar=true" target="_blank" rel="noopener" class="cta-join">Join the Team</a>
        </p>
        <p class="cta">
          <a href="https://discord.com/invite/HtKyx8j4Cs" target="_blank" rel="noopener" class="cta-discord">Join Discord</a>
          <a href="https://www.nordicglobalsolutions.com" target="_blank" rel="noopener">www.nordicglobalsolutions.com</a>
        </p>
        <p class="cta-note">Join our weekly Discord meetings.</p>
        <p class="company">Nordic Global Solutions</p>
      </div>
    </div>
  </div>

  <div class="slide-num"><span id="current">1</span> / <span id="total">4</span></div>
  <div class="footer-nav">
    <button id="prev" aria-label="Previous slide">←</button>
    <button id="next" aria-label="Next slide">→</button>
  </div>

  <script>
    const slides = document.querySelectorAll('.slide');
    const total = slides.length;
    const currentEl = document.getElementById('current');
    document.getElementById('total').textContent = total;

    let idx = 0;
    function show(i) {
      idx = Math.max(0, Math.min(i, total - 1));
      slides.forEach((s, k) => s.classList.toggle('active', k === idx));
      currentEl.textContent = idx + 1;
    }
    document.getElementById('prev').onclick = () => show(idx - 1);
    document.getElementById('next').onclick = () => show(idx + 1);
    document.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft') show(idx - 1);
      if (e.key === 'ArrowRight') show(idx + 1);
    });

    let touchStartX = 0;
    document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? show(idx + 1) : show(idx - 1);
    }, { passive: true });
  </script>
</Base>

<style>
  :root {
    --bg-mid: #08080d;
    --surface: rgba(255,255,255,0.03);
    --surface-glass: rgba(255,255,255,0.04);
  }
  @media (min-width: 769px) {
    body { height: 100vh; overflow: hidden; }
  }

  .slides-wrapper {
    position: relative;
    min-height: 100vh;
    width: 100%;
  }
  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    min-height: 100vh;
    padding: 4rem 5rem;
    flex-direction: column;
    justify-content: center;
    z-index: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }
  .slide.active {
    position: relative;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  @media (max-width: 768px) {
    .slide { min-height: 100vh; height: auto; padding: 5rem 1.5rem 6rem; justify-content: flex-start; }
  }

  .slide h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.75rem, 5vw, 3.75rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .slide h1 .highlight {
    background: linear-gradient(135deg, var(--accent) 0%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .slide p { font-size: clamp(0.95rem, 2vw, 1.2rem); line-height: 1.8; color: var(--text-muted); margin: 0 0 1rem; font-weight: 300; }
  .slide code {
    background: var(--surface-glass);
    padding: 0.2em 0.5em;
    border-radius: 6px;
    font-size: 0.9em;
    color: var(--gold-soft);
  }
  .slide ul { font-size: clamp(0.9rem, 2vw, 1.15rem); line-height: 2; color: var(--text-muted); padding-left: 1.5rem; list-style: none; }
  .slide ul li { margin-bottom: 0.6rem; padding-left: 1rem; position: relative; font-weight: 300; }
  .slide ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 4px;
    height: 4px;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    border-radius: 50%;
  }
  .slide ul li strong { color: var(--gold-soft); font-weight: 500; }

  .hero { text-align: center; }
  .hero h1 { font-size: clamp(2rem, 6vw, 4.5rem); margin-bottom: 1.5rem; }
  .hero .tagline { font-size: 1.5rem; color: var(--text-muted); margin-bottom: 1.5rem; font-weight: 400; }
  .hero p { max-width: 32rem; margin-left: auto; margin-right: auto; }
  .slide .cta { font-size: 1.35rem; margin-top: 2.5rem; }
  .slide .cta-note { font-size: 1rem; color: var(--text-dim); margin-top: 0.5rem; font-style: italic; }
  .slide .cta-join {
    display: inline-block;
    background: linear-gradient(135deg, rgba(212,175,55,0.2) 0%, rgba(0,229,255,0.15) 100%);
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 0.75rem 1.5rem;
    font-size: 1.1rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 12px;
    margin-bottom: 1rem;
    transition: all 0.2s;
  }
  .slide .cta-join:hover {
    background: linear-gradient(135deg, rgba(212,175,55,0.3) 0%, rgba(0,229,255,0.25) 100%);
    border-color: var(--gold-soft);
    color: var(--gold-soft);
    transform: translateY(-1px);
  }
  .slide .cta a:not(.cta-join):not(.cta-discord) {
    color: var(--gold-soft);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid rgba(212,175,55,0.5);
    transition: color 0.2s, border-color 0.2s;
  }
  .slide .cta a:not(.cta-join):not(.cta-discord):hover { color: var(--gold); border-bottom-color: var(--gold); }
  .slide .cta-discord {
    display: inline-block;
    background: #5865F2;
    border: 1px solid #5865F2;
    color: #fff !important;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    margin-right: 1rem;
    margin-bottom: 0.5rem;
    border-bottom: none !important;
  }
  .slide .cta-discord:hover {
    background: #4752C4;
    border-color: #4752C4;
    color: #fff !important;
    transform: translateY(-1px);
  }

  .caps {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    margin: 1.5rem 0;
  }
  .hero .divider { margin: 2rem auto; background: linear-gradient(90deg, transparent, var(--gold), transparent); width: 80px; }

  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.5rem;
    min-height: 44px;
    transition: color 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .back-link:hover { color: var(--gold); }
  @media (min-width: 769px) {
    .back-link { top: 2rem; left: 2.5rem; padding: 0; }
  }

  .footer-nav {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    gap: 0.5rem;
    z-index: 100;
  }
  @media (min-width: 769px) {
    .footer-nav { bottom: 2rem; right: 2.5rem; }
  }
  .footer-nav button {
    background: var(--surface-glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 48px;
    height: 48px;
    min-width: 48px;
    min-height: 48px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 1.25rem;
    transition: all 0.2s;
  }
  .footer-nav button:hover {
    background: rgba(212,175,55,0.15);
    border-color: var(--border-glow);
    color: var(--gold);
  }
  .slide-num {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  @media (min-width: 769px) {
    .slide-num { bottom: 2rem; left: 2.5rem; font-size: 0.85rem; }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .slide > * {
    opacity: 0;
  }
  .slide.active > * {
    animation: fadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .slide.active > *:nth-child(1) { animation-delay: 0.08s; }
  .slide.active > *:nth-child(2) { animation-delay: 0.14s; }
  .slide.active > *:nth-child(3) { animation-delay: 0.2s; }
  .slide.active > *:nth-child(4) { animation-delay: 0.26s; }
  .slide.active > *:nth-child(5) { animation-delay: 0.32s; }
  .slide.active > *:nth-child(6) { animation-delay: 0.38s; }
  .slide.active > *:nth-child(7) { animation-delay: 0.44s; }
  .slide.active > *:nth-child(8) { animation-delay: 0.5s; }
  .slide.active ul li {
    opacity: 0;
    animation: fadeInUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .slide.active ul li:nth-child(1) { animation-delay: 0.35s; }
  .slide.active ul li:nth-child(2) { animation-delay: 0.42s; }
  .slide.active ul li:nth-child(3) { animation-delay: 0.49s; }
  .slide.active ul li:nth-child(4) { animation-delay: 0.56s; }
  @media (prefers-reduced-motion: reduce) {
    .slide { transition: none; }
    .slide > *, .slide.active ul li {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
