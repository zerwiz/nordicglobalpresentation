---
import Base from '../layouts/Base.astro';
const siteUrl = 'https://nordicglobal.netlify.app';
---

<Base>
  <Fragment slot="head">
    <title>Build the Future of Tech — Nordic Global Solutions Presentation</title>
    <meta name="description" content="Hiring presentation: Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite. 11 slides. We're seeking people to build the future of technology." />
    <meta name="keywords" content="Nordic Global Solutions, Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite, Debugger, presentation, hiring, tech jobs, AI operating system, Solin, knowledge graph, RAG" />
    <meta name="author" content="Nordic Global Solutions" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />
    <meta name="theme-color" content="#030306" />
    <meta name="color-scheme" content="dark" />
    <meta name="application-name" content="Nordic Global Solutions Presentation" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="subject" content="Nordic Global Solutions hiring presentation — AI, workspace, marketing platforms" />
    <meta name="copyright" content="Nordic Global Solutions" />
    <meta name="rating" content="general" />
    <meta name="distribution" content="global" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="NGS Slides" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="msapplication-TileColor" content="#030306" />
    <meta name="msapplication-TileImage" content="/icon.svg" />
    <link rel="canonical" href={`${siteUrl}/slides`} />
    <link rel="prev" href={`${siteUrl}/`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Build the Future of Tech — Nordic Global Solutions Presentation" />
    <meta property="og:description" content="Hiring presentation: Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite. 11 slides. Join us to build the future." />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:secure_url" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Nordic Global Solutions — Build the Future of Tech" />
    <meta property="og:url" content={`${siteUrl}/slides`} />
    <meta property="og:site_name" content="Nordic Global Solutions" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="en_GB" />
    <meta property="og:determiner" content="auto" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Build the Future of Tech — Nordic Global Solutions Presentation" />
    <meta name="twitter:description" content="Hiring presentation: Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite. 11 slides. Join us." />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:image:alt" content="Nordic Global Solutions — Build the Future of Tech" />
    <meta name="twitter:label1" content="Slides" />
    <meta name="twitter:data1" content="11" />
    <meta name="twitter:label2" content="Platforms" />
    <meta name="twitter:data2" content="Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "PresentationDigitalDocument",
          "@id": `${siteUrl}/slides#presentation`,
          "name": "Build the Future of Tech — Nordic Global Solutions",
          "description": "Hiring presentation: Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite. 11 slides. We're seeking people to build the future of technology.",
          "url": `${siteUrl}/slides`,
          "author": { "@type": "Organization", "name": "Nordic Global Solutions", "url": siteUrl },
          "publisher": { "@type": "Organization", "name": "Nordic Global Solutions", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/icon.svg` } },
          "image": `${siteUrl}/og-image.png`,
          "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/slides` }
        },
        {
          "@type": "WebPage",
          "@id": `${siteUrl}/slides#webpage`,
          "name": "Build the Future of Tech — Nordic Global Solutions Presentation",
          "description": "Hiring presentation: Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, AI Dev Suite. 11 slides.",
          "url": `${siteUrl}/slides`,
          "isPartOf": { "@type": "WebSite", "name": "Nordic Global Solutions", "url": siteUrl },
          "breadcrumb": {
            "@type": "BreadcrumbList",
            "itemListElement": [
              { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
              { "@type": "ListItem", "position": 2, "name": "Presentation", "item": `${siteUrl}/slides` }
            ]
          }
        }
      ]
    })} />
  </Fragment>

  <a href="/" class="back-link">← Back to landing</a>

  <div class="slides-wrapper">
    <div class="slide active" data-n="1">
      <div class="hero">
        <h1>Build the <span class="highlight">Future</span> of Tech</h1>
        <div class="divider"></div>
        <p class="tagline">We're looking for people who want to shape what comes next.</p>
        <p>Nordic Global Solutions develops platforms that help people and teams work smarter.</p>
        <p class="company">www.nordicglobalsolutions.com</p>
      </div>
    </div>

    <div class="slide" data-n="2">
      <p class="caps">What We Build</p>
      <h1>Our Platforms</h1>
      <p>We focus on tools that make a real difference—AI that helps you work, workspaces that bring teams together, and automation that scales your reach.</p>
      <ul>
        <li><strong>Ona</strong> — Your AI operating system</li>
        <li><strong>WorkFlowSpace</strong> — One place for teams</li>
        <li><strong>Affiliate Flow</strong> — Marketing automation</li>
        <li><strong>BitNexus</strong> — Decentralized affiliate revenue platform</li>
        <li><strong>Mimir</strong> — Knowledge & AI</li>
        <li><strong>AI Dev Suite</strong> — Local AI tooling; Debugger & Observer</li>
      </ul>
    </div>

    <div class="slide" data-n="3">
      <p class="caps">Ona</p>
      <h1>Your AI Teammate</h1>
      <p>Ona is a system where AI helps you get things done. Instead of one chatbot, you get a whole squad.</p>
      <div class="two-col">
        <div class="card">
          <h2>Solin — Your lead agent</h2>
          <p>You talk to Solin. Solin brings in the right specialist when you need them: writers, researchers, developers, marketers.</p>
        </div>
        <div class="card">
          <h2>How you use it</h2>
          <p>Web, Telegram, Discord, WhatsApp, Signal. One thread, all your agents. Text or voice.</p>
        </div>
      </div>
    </div>

    <div class="slide" data-n="4">
      <p class="caps">Ona — What You Can Do</p>
      <h1>Content, Research, Code, Design</h1>
      <ul>
        <li><strong>Content</strong> — Drafts, blogs, social posts, landing pages, emails</li>
        <li><strong>Research</strong> — Competitor research, trends, SEO</li>
        <li><strong>Code</strong> — Implement features, run builds, scripts</li>
        <li><strong>Design</strong> — Mockups, layouts, visuals</li>
        <li><strong>Projects</strong> — Tasks, todos, follow-ups</li>
        <li><strong>Integrations</strong> — Google, email, SMS, social, Notion</li>
      </ul>
      <p>All in one place. Secure. You can self-host or use the cloud.</p>
    </div>

    <div class="slide" data-n="5">
      <p class="caps">WorkFlowSpace</p>
      <h1>One Workspace for Teams</h1>
      <p>A single place for calendar, chat, tasks, and docs. Google Workspace integration—Gmail, Drive, Calendar, Meet, Docs/Sheets, Tasks.</p>
      <div class="two-col">
        <div class="card">
          <h2>Editor & AI</h2>
          <ul>
            <li>Split-view: chat + code side by side</li>
            <li>AI multi-model routing (GPT-4, Claude, Gemini, Ollama)</li>
            <li>Strategy Agent, preview, export (PNG, PDF)</li>
          </ul>
        </div>
        <div class="card">
          <h2>Tasks & Knowledge</h2>
          <ul>
            <li>Kanban boards, drag-and-drop, custom workflows</li>
            <li>Knowledge base, semantic search, mind maps</li>
            <li>Deep Work Mode, WCAG 2.1 AA</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="slide" data-n="6">
      <p class="caps">Affiliate Flow</p>
      <h1>Marketing Automation</h1>
      <p>Full-stack affiliate marketing: landing pages, communications, and AI-generated social content. One platform for your entire funnel.</p>
      <div class="two-col">
        <div class="card">
          <h2>Landing & Comms</h2>
          <ul>
            <li>Landing pages — Astro, static HTML, Netlify deploy</li>
            <li>Email, SMS, WhatsApp — AI-generated messages</li>
            <li>Contact groups, tone options, Gmail/Outlook/SMTP</li>
          </ul>
        </div>
        <div class="card">
          <h2>AI Social & Dashboard</h2>
          <ul>
            <li>LinkedIn, X, Instagram, TikTok, YouTube</li>
            <li>Platform prompts, schedule or push now</li>
            <li>Calendar, contacts, products, affiliates</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="slide" data-n="7">
      <p class="caps">BitNexus</p>
      <h1>Decentralized Affiliate Revenue</h1>
      <p>AI-powered platform combining automated trading, network marketing, and content generation. Passive income through MEV & XAB bots, affiliate commissions, and NXC token.</p>
      <div class="two-col">
        <div class="card">
          <h2>Key Features</h2>
          <ul>
            <li>Social networking — Chat, friends</li>
            <li>Alliance Network — MLM, tier progression</li>
            <li>Marketplace — Due diligence for products (S–F ranking)</li>
            <li>Trust — ISO 27001 & 27701, CertiK, KPMG audits</li>
            <li>MEV Bot & XAB Bot staking (10–18% APY)</li>
            <li>AI Content Generator</li>
          </ul>
        </div>
        <div class="card">
          <h2>Launch</h2>
          <p>Genesis phase: 500 licenses. Launch January 21, 2026. NXC token. $227B+ market opportunity.</p>
        </div>
      </div>
    </div>

    <div class="slide" data-n="8">
      <p class="caps">Mimir</p>
      <h1>Knowledge & AI</h1>
      <p>Multi-tenant Knowledge & AI app: Drive, Mind Map, RAG-powered Chat, Mermaid sequence diagrams.</p>
      <div class="two-col">
        <div class="card">
          <h2>Modules</h2>
          <ul>
            <li>Drive — Files, folders, sync to Knowledge Base</li>
            <li>Mind Map — Knowledge graph, generate Mermaid</li>
            <li>Chat — RAG, citations, occurrence queries</li>
            <li>Sequence Diagrams — Mermaid editor</li>
          </ul>
        </div>
        <div class="card">
          <h2>Deploy</h2>
          <p>Web (mimir-drive.fly.dev), Electron desktop, or fully local. Ollama, LM Studio, Mimir backend. Zerwiz · WhyNot Productions.</p>
        </div>
      </div>
    </div>

    <div class="slide" data-n="9">
      <p class="caps">AI Dev Suite</p>
      <h1>Local AI Tooling & Debugger</h1>
      <p>100% local AI for developers. One-click install: Zed, OpenCode, Ollama, LM Studio. Chat with extended thinking (Qwen3, DeepSeek R1). Memory, document drive, RAG research.</p>
      <div class="two-col">
        <div class="card">
          <h2>Debugger & Observer</h2>
          <p>Diagnose "(no response)", "terminated", "Cannot reach API". Status, logs, test chat, LLM analysis. Terminal observer. A2A agent.</p>
        </div>
        <div class="card">
          <h2>Components</h2>
          <ul>
            <li>Electron app — Chat, Drive, Memory, Tools</li>
            <li>RAG — PDF, DOCX; hybrid BM25+vector</li>
            <li>TUI, web, desktop — works offline</li>
          </ul>
        </div>
      </div>
      <p>Zerwiz · WhyNot Productions</p>
    </div>

    <div class="slide" data-n="10">
      <p class="caps">How We Build</p>
      <h1>Our Stack</h1>
      <p>React, TypeScript, Rust, Elixir, Phoenix. Cursor, Google AI Suite. We use OpenAI and Claude, and support self-hosted models like Ollama.</p>
    </div>

    <div class="slide" data-n="11">
      <div class="hero">
        <h1>Join the <span class="highlight">Team</span></h1>
        <div class="divider"></div>
        <p class="tagline">Help us build Ona, WorkFlowSpace, Affiliate Flow, BitNexus, Mimir, and AI Dev Suite.</p>
        <p class="cta">
          <a href="https://cal.com/whynotproductions/join-the-team?duration=15&overlayCalendar=true" target="_blank" rel="noopener" class="cta-join">Join the Team</a>
        </p>
        <p class="cta">
          <a href="https://www.nordicglobalsolutions.com" target="_blank" rel="noopener">www.nordicglobalsolutions.com</a>
        </p>
        <p class="company">Build the future. Nordic Global Solutions.</p>
        <p class="part-of">
          <a href="https://affliateflow.netlify.app/partners/svein-erik-nilsen" target="_blank" rel="noopener">Svein-Erik Nilsen</a> · <a href="https://affliateflow.netlify.app/partners/craig-martin" target="_blank" rel="noopener">Craig Martin</a> · <a href="https://whynotproductions.netlify.app" target="_blank" rel="noopener">Zerwiz</a> — Co-founders · <a href="https://whynotproductions.netlify.app" target="_blank" rel="noopener">WhyNot Productions</a>
        </p>
      </div>
    </div>
  </div>

  <div class="slide-num"><span id="current">1</span> / <span id="total">11</span></div>
  <div class="footer-nav">
    <button id="prev" aria-label="Previous slide">←</button>
    <button id="next" aria-label="Next slide">→</button>
  </div>

  <script>
    const slides = document.querySelectorAll('.slide');
    const total = slides.length;
    const currentEl = document.getElementById('current');
    document.getElementById('total').textContent = total;

    let idx = 0;
    function show(i) {
      idx = Math.max(0, Math.min(i, total - 1));
      slides.forEach((s, k) => s.classList.toggle('active', k === idx));
      currentEl.textContent = idx + 1;
    }
    document.getElementById('prev').onclick = () => show(idx - 1);
    document.getElementById('next').onclick = () => show(idx + 1);
    document.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft') show(idx - 1);
      if (e.key === 'ArrowRight') show(idx + 1);
    });

    let touchStartX = 0;
    document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    document.addEventListener('touchend', e => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? show(idx + 1) : show(idx - 1);
    }, { passive: true });
  </script>
</Base>

<style>
  :root {
    --bg-mid: #08080d;
    --surface: rgba(255,255,255,0.03);
    --accent-cyan: #5ce1e6;
  }
  @media (min-width: 769px) {
    body { height: 100vh; overflow: hidden; }
  }

  .slides-wrapper {
    position: relative;
    min-height: 100vh;
    width: 100%;
  }
  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    min-height: 100vh;
    padding: 4rem 5rem;
    flex-direction: column;
    justify-content: center;
    z-index: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }
  .slide.active {
    position: relative;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  @media (max-width: 768px) {
    .slide { min-height: 100vh; height: auto; padding: 5rem 1.5rem 6rem; justify-content: flex-start; }
  }

  .slide h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.75rem, 5vw, 3.75rem);
    font-weight: 700;
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .slide h1 .highlight { background: linear-gradient(135deg, var(--accent) 0%, var(--gold) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .slide h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--gold-soft);
    letter-spacing: -0.01em;
  }
  .slide p { font-size: clamp(0.95rem, 2vw, 1.2rem); line-height: 1.8; color: var(--text-muted); margin: 0 0 1rem; font-weight: 300; }
  .slide ul { font-size: clamp(0.9rem, 2vw, 1.15rem); line-height: 2; color: var(--text-muted); padding-left: 1.5rem; list-style: none; }
  .slide ul li { margin-bottom: 0.6rem; padding-left: 1rem; position: relative; font-weight: 300; }
  .slide ul li::before { content: ''; position: absolute; left: 0; top: 0.65em; width: 4px; height: 4px; background: linear-gradient(135deg, var(--accent), var(--gold)); border-radius: 50%; }
  .slide ul li strong { color: var(--gold-soft); font-weight: 500; }
  .slide .cta { font-size: 1.35rem; margin-top: 2.5rem; }
  .slide .cta-join {
    display: inline-block;
    background: linear-gradient(135deg, rgba(212,175,55,0.2) 0%, rgba(0,229,255,0.15) 100%);
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 0.75rem 1.5rem;
    font-size: 1.1rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 12px;
    margin-bottom: 1rem;
    transition: all 0.2s;
  }
  .slide .cta-join:hover {
    background: linear-gradient(135deg, rgba(212,175,55,0.3) 0%, rgba(0,229,255,0.25) 100%);
    border-color: var(--gold-soft);
    color: var(--gold-soft);
    transform: translateY(-1px);
  }
  .slide .cta a {
    color: var(--gold-soft);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding-bottom: 2px;
    border-bottom: 1px solid rgba(212,175,55,0.5);
    transition: color 0.2s, border-color 0.2s;
  }
  .slide .cta a:hover { color: var(--gold); border-bottom-color: var(--gold); }

  .hero { text-align: center; }
  .hero h1 { font-size: clamp(2rem, 6vw, 4.5rem); margin-bottom: 1.5rem; }
  .hero .tagline { font-size: 1.5rem; color: var(--text-muted); margin-bottom: 1.5rem; font-weight: 400; }
  .hero p:not(.tagline):not(.cta) { max-width: 32rem; margin-left: auto; margin-right: auto; }
  .hero .company {
    font-size: 1rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 3rem;
    font-weight: 500;
  }
  .hero .part-of {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .hero .part-of a {
    color: var(--gold-soft);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,0.4);
  }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: 1.5rem; }
    .two-col .card { padding: 1.25rem; }
  }
  .two-col .card {
    background: var(--surface-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 16px;
    border-left: 3px solid var(--gold);
  }

  .caps {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .footer-nav {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    gap: 0.5rem;
    z-index: 100;
  }
  @media (min-width: 769px) {
    .footer-nav { bottom: 2rem; right: 2.5rem; }
  }
  .footer-nav button {
    background: var(--surface-glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    color: var(--text-muted);
    width: 48px;
    height: 48px;
    min-width: 48px;
    min-height: 48px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 1.25rem;
    transition: all 0.2s;
  }
  .footer-nav button:hover {
    background: rgba(212,175,55,0.15);
    border-color: var(--border-glow);
    color: var(--gold);
  }
  .slide-num {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    color: var(--text-dim);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  @media (min-width: 769px) {
    .slide-num { bottom: 2rem; left: 2.5rem; font-size: 0.85rem; }
  }

  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    min-height: 44px;
    min-width: 44px;
    transition: color 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .back-link:hover { color: var(--gold); }
  @media (min-width: 769px) {
    .back-link { top: 2rem; left: 2.5rem; padding: 0; }
  }

  .card { background: var(--surface-glass); backdrop-filter: blur(20px); padding: 1.5rem 2rem; border-radius: 16px; border: 1px solid var(--border); }

  .divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    margin: 1.5rem 0;
  }
  .hero .divider { margin: 2rem auto; background: linear-gradient(90deg, transparent, var(--gold), transparent); width: 80px; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .slide > * {
    opacity: 0;
  }
  .slide.active > * {
    animation: fadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .slide.active > *:nth-child(1) { animation-delay: 0.08s; }
  .slide.active > *:nth-child(2) { animation-delay: 0.14s; }
  .slide.active > *:nth-child(3) { animation-delay: 0.2s; }
