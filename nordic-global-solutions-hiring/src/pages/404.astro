---
import Base from '../layouts/Base.astro';
const siteUrl = 'https://nordicglobal.netlify.app';
---

<Base>
  <Fragment slot="head">
    <title>404 — Page Not Found | Nordic Global Solutions</title>
    <meta name="description" content="Page not found. Return to Nordic Global Solutions landing page or presentation." />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#030306" />
    <meta name="application-name" content="Nordic Global Solutions" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="msapplication-TileColor" content="#030306" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="404 — Page Not Found | Nordic Global Solutions" />
    <meta property="og:description" content="Page not found. Return to Nordic Global Solutions." />
    <meta property="og:url" content={`${siteUrl}/404`} />
    <meta property="og:site_name" content="Nordic Global Solutions" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="404 — Nordic Global Solutions" />
  </Fragment>

  <div class="content">
    <h1>404 — Page Not Found</h1>
    <p>This page doesn't exist. Return to the landing page or presentation.</p>
    <div class="links">
      <a href="/">Go to landing page</a>
      <a href="/slides">View presentation</a>
    </div>
  </div>
</Base>

<style>
  body {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
    text-align: center;
  }
  body::before {
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(0,229,255,0.06) 0%, transparent 50%),
      linear-gradient(180deg, #030306 0%, #0a0a12 100%);
  }
  .content { position: relative; z-index: 1; }
  .content h1 { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 600; margin: 0 0 0.5rem; color: var(--text); }
  .content p { color: var(--text-muted); margin: 0 0 1.5rem; }
  .content a {
    color: var(--gold-soft);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,0.5);
    padding-bottom: 2px;
    font-weight: 500;
  }
  .content a:hover { color: var(--gold); }

  .links { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
  @media (max-width: 768px) {
    body { padding: 1.5rem; }
    .content h1 { font-size: 1.5rem; }
    .links { flex-direction: column; align-items: center; }
    .links a { padding: 0.5rem 0; min-height: 44px; display: inline-flex; align-items: center; }
  }
</style>
